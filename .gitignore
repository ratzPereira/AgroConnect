# ═══════════════════════════════════════════
# AgroConnect .gitignore
# ═══════════════════════════════════════════
docs/
# ── IDE ──
.idea/
*.iml
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── Java / Maven ──
backend/target/
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# ── Node / Frontend ──
frontend/node_modules/
frontend/dist/
*.tsbuildinfo

# ── Environment & Secrets ──
.env
.env.*
!.env.example

# ── Docker volumes (local data) ──
docker/postgres-data/
docker/redis-data/
docker/minio-data/
docker/grafana-data/
docker/prometheus-data/

# ── Logs ──
*.log
logs/
backend/logs/

# ── Test & Coverage ──
frontend/coverage/
*.lcov

# ── SonarQube ──
.scannerwork/

# ── Misc ──
*.bak
*.tmp
*.temp
