# ═══════════════════════════════════════════
# AgroConnect — Environment Variables
# Copy to .env and adjust values as needed
# ═══════════════════════════════════════════

# ── PostgreSQL ──
POSTGRES_DB=agroconnect
POSTGRES_USER=agroconnect
POSTGRES_PASSWORD=dev_password_123

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── MinIO ──
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=agroconnect

# ── JWT ──
JWT_SECRET=dev-jwt-secret-at-least-256-bits-long-for-hs256-algorithm

# ── Stripe (test mode) ──
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
# Default URLs (para prod):
# STRIPE_ONBOARDING_RETURN_URL=https://agroconnect.pt/provider/stripe/return
# STRIPE_ONBOARDING_REFRESH_URL=https://agroconnect.pt/provider/stripe/refresh

# ── Commission ──
COMMISSION_RATE=0.12

# ── Spring ──
SPRING_PROFILES_ACTIVE=dev
