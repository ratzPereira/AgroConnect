  "panels": [
    {
      "title": "Service Requests Created (per hour)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(http_server_requests_seconds_count{application=\"agroconnect\", uri=\"/api/v1/requests\", method=\"POST\", status=\"201\"}[1h])",
          "legendFormat": "Requests Created",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Proposals Submitted (per hour)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
