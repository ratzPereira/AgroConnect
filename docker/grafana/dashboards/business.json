      "options": {
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "topk(10, sum(increase(http_server_requests_seconds_count{application=\"agroconnect\"}[1h])) by (uri))",
          "legendFormat": "{{uri}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Chat Messages Sent (per hour)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
