  "panels": [
    {
      "title": "Registrations (24h)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#22C55E", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "increase(http_server_requests_seconds_count{application=\"agroconnect\", uri=\"/api/v1/auth/register\", method=\"POST\", status=\"201\"}[24h])",
          "legendFormat": "New Users",
          "refId": "A"
        }
      ]
    },
