      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(http_server_requests_seconds_count{application=\"agroconnect\", uri=~\"/api/v1/requests/.*/proposals\", method=\"POST\", status=\"201\"}[1h])",
          "legendFormat": "Proposals Submitted",
          "refId": "A"
        }
