    {
      "title": "HTTP Status Distribution (24h)",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "2xx" },
