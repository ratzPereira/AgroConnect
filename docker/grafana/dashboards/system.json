{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#EAB308", "value": null },
              { "color": "#22C55E", "value": 3600 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "process_uptime_seconds{application=\"agroconnect\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Requests Served",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#3B82F6", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(http_server_requests_seconds_count{application=\"agroconnect\"})",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "title": "JVM Heap Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#22C55E", "value": null },
              { "color": "#EAB308", "value": 0.7 },
              { "color": "#EF4444", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\", application=\"agroconnect\"}) / sum(jvm_memory_max_bytes{area=\"heap\", application=\"agroconnect\"})",
          "legendFormat": "Heap %",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Threads",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#8B5CF6", "value": null },
              { "color": "#EF4444", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"agroconnect\"}",
          "legendFormat": "Live",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#22C55E", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"agroconnect\"}[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Response Time",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#22C55E", "value": null },
              { "color": "#EAB308", "value": 200 },
              { "color": "#EF4444", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"agroconnect\"}[5m])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#22C55E", "value": null },
              { "color": "#EAB308", "value": 0.01 },
              { "color": "#EF4444", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"agroconnect\", status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{application=\"agroconnect\"}[5m]))",
          "legendFormat": "5xx %",
          "refId": "A"
        }
      ]
    },
    {
      "title": "DB Pool Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#22C55E", "value": null },
              { "color": "#EAB308", "value": 0.6 },
              { "color": "#EF4444", "value": 0.85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"agroconnect\"} / hikaricp_connections_max{application=\"agroconnect\"}",
          "legendFormat": "Pool %",
          "refId": "A"
        }
      ]
    },
    {
      "title": "JVM Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "gradientMode": "scheme"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Max" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "fixedColor": "#EF4444", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\", application=\"agroconnect\"}) by (id)",
          "legendFormat": "Used - {{id}}",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{area=\"heap\", application=\"agroconnect\"})",
          "legendFormat": "Max",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Process CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "gradientMode": "scheme"
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"agroconnect\"}",
          "legendFormat": "Application CPU",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage{application=\"agroconnect\"}",
          "legendFormat": "System CPU",
          "refId": "B"
        }
      ]
    },
    {
      "title": "HTTP Request Rate (by endpoint)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"agroconnect\"}[5m])) by (method, uri)",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#22C55E", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#EAB308", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#EF4444", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"agroconnect\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"agroconnect\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"agroconnect\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "HTTP Errors (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#EAB308", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#EF4444", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"agroconnect\", status=~\"4..\"}[5m]))",
          "legendFormat": "4xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"agroconnect\", status=~\"5..\"}[5m]))",
          "legendFormat": "5xx",
          "refId": "B"
        }
      ]
    },
    {
      "title": "HikariCP Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Active" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#3B82F6", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Idle" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#22C55E", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Pending" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#EF4444", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Max" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#6B7280", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"agroconnect\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"agroconnect\"}",
          "legendFormat": "Idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"agroconnect\"}",
          "legendFormat": "Pending",
          "refId": "C"
        },
        {
          "expr": "hikaricp_connections_max{application=\"agroconnect\"}",
          "legendFormat": "Max",
          "refId": "D"
        }
      ]
    },
    {
      "title": "GC Pause Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "drawStyle": "bars"
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"agroconnect\"}[5m]) / rate(jvm_gc_pause_seconds_count{application=\"agroconnect\"}[5m])",
          "legendFormat": "{{action}} - {{cause}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Live" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#3B82F6", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Daemon" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#8B5CF6", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Peak" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#EAB308", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"agroconnect\"}",
          "legendFormat": "Live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"agroconnect\"}",
          "legendFormat": "Daemon",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"agroconnect\"}",
          "legendFormat": "Peak",
          "refId": "C"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["agroconnect", "system"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AgroConnect - System Metrics",
  "uid": "agroconnect-system",
  "version": 1
}
